<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.6//EN' 'http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd'>
<nta>
	<declaration>
clock reqAge, cut, mesh, wait, rec;
chan req, ack, recover;
  </declaration>
	<template>
		<name>Driver</name>
		<location id="id0" x="-323" y="-25">
			<name x="-343" y="-55">Idle</name>
			<label kind="invariant" x="-399" y="-8">wait &lt;= 20</label>
		</location>
		<location id="id1" x="-25" y="-25">
			<name x="-8" y="-33">Waiting</name>
		</location>
		<init ref="id0"/>
		<transition id="id2">
			<source ref="id0"/>
			<target ref="id1"/>
			<label kind="guard" x="-204" y="-161">wait &gt;= 5</label>
			<label kind="synchronisation" x="-187" y="-144">req!</label>
			<label kind="assignment" x="-212" y="-127">wait = 0</label>
			<nail x="-263" y="-102"/>
			<nail x="-93" y="-102"/>
		</transition>
		<transition id="id3">
			<source ref="id1"/>
			<target ref="id0"/>
			<label kind="synchronisation" x="-195" y="-68">ack?</label>
			<label kind="assignment" x="-212" y="-51">wait = 0</label>
			<nail x="-102" y="-25"/>
		</transition>
		<transition id="id4">
			<source ref="id1"/>
			<target ref="id0"/>
			<label kind="synchronisation" x="-212" y="8">recover?</label>
			<label kind="assignment" x="-212" y="25">wait = 0</label>
			<nail x="-93" y="51"/>
			<nail x="-263" y="51"/>
		</transition>
	</template>
	<template>
		<name>GearController</name>
		<location id="id5" x="-291" y="117">
			<name x="-350" y="109">Ready</name>
		</location>
		<location id="id6" x="-36" y="117">
			<name x="-61" y="87">Cut</name>
			<label kind="invariant" x="-71" y="137">cut &lt;= 1</label>
		</location>
		<location id="id7" x="314" y="117">
			<name x="329" y="109">Engage</name>
			<label kind="invariant" x="389" y="109">mesh &lt;= 3</label>
		</location>
		<location id="id8" x="314" y="297">
			<name x="329" y="287">Late</name>
			<label kind="invariant" x="284" y="322">rec &lt;= 1</label>
		</location>
		<init ref="id5"/>
		<transition id="id9">
			<source ref="id5"/>
			<target ref="id6"/>
			<label kind="synchronisation" x="-245" y="70">req?</label>
			<label kind="assignment" x="-265" y="92">reqAge = 0, cut = 0</label>
		</transition>
		<transition id="id10">
			<source ref="id6"/>
			<target ref="id7"/>
			<label kind="guard" x="55" y="75">cut &gt;= 1 &amp;&amp; reqAge &lt;= 4</label>
			<label kind="assignment" x="100" y="100">mesh = 0</label>
		</transition>
		<transition id="id11">
			<source ref="id7"/>
			<target ref="id5"/>
			<label kind="guard" x="-96" y="-61">mesh &gt;= 3 &amp;&amp; reqAge &lt;= 4</label>
			<label kind="synchronisation" x="-20" y="-44">ack!</label>
			<label kind="assignment" x="-113" y="-27">reqAge = 0, cut = 0, mesh = 0</label>
			<nail x="314" y="-3"/>
			<nail x="-206" y="-3"/>
		</transition>
		<transition id="id12">
			<source ref="id6"/>
			<target ref="id8"/>
			<label kind="guard" x="142" y="170">reqAge &gt; 4</label>
			<label kind="assignment" x="142" y="193">rec = 0</label>
			<nail x="91" y="185"/>
		</transition>
		<transition id="id13">
			<source ref="id7"/>
			<target ref="id8"/>
			<label kind="guard" x="321" y="187">reqAge &gt; 4</label>
			<label kind="assignment" x="321" y="210">rec = 0</label>
		</transition>
		<transition id="id14">
			<source ref="id8"/>
			<target ref="id5"/>
			<label kind="guard" x="-113" y="233">rec &gt;= 1</label>
			<label kind="synchronisation" x="-113" y="253">recover!</label>
			<label kind="assignment" x="-183" y="273">reqAge = 0, cut = 0, mesh = 0, rec = 0</label>
			<nail x="-206" y="297"/>
		</transition>
	</template>
	<system>
Driver0 = Driver();
Controller = GearController();
system Driver0, Controller;
  </system>
	<queries>
		<query>
			<formula>A[] (Controller.Engage imply cut &gt;= 2)</formula>
			<comment>P1: gear engagement must not start before at least two time units of torque cut.</comment>
			<option key="--diagnostic" value="-1"/>
			<result outcome="failure" type="quality" timestamp="2026-07-05 12:30:51 +0800">
				<option key="--diagnostic" value="-1"/>
			</result>
		</query>
		<query>
			<formula>A[] not Controller.Late</formula>
			<comment>P2: the shift request must be acknowledged within the response deadline.</comment>
			<result outcome="success" type="quality" timestamp="2026-07-05 12:30:43 +0800">
			</result>
		</query>
		<query>
			<formula>A[] not deadlock</formula>
			<comment>P3: the cyclic controller must not deadlock.</comment>
			<result outcome="success" type="quality" timestamp="2026-07-05 12:30:45 +0800">
			</result>
		</query>
	</queries>
</nta>
